__pycache__/
*.pyc
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/

# Cython distribution build byproducts — generated from .py by setup.py and
# deleted again at the start of every build-dist.sh run.  Never hand-written.
src/siar/**/*.c
*.so

# Local config + workspace
siar.toml
*.local.*

# SIAR workspace artefacts (feature cache, results DB, run outputs)
.siar/
*.db
*.db-wal
*.db-shm
*.npy

# Tutorial demo corpus (regenerate with the tutorial scripts)
siar-demo*/
tutorials/quick_start/corpus/
